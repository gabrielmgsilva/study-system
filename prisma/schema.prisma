generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  user
  admin
}

enum LimitUnit {
  day
  week
  month
}

enum StudyMode {
  flashcard
  practice
  test
}

enum TestStatus {
  in_progress
  completed
  canceled
  expired
}

enum QuestionType {
  single_choice
}

enum QuestionStatus {
  draft
  review
  published
  archived
}

enum ContentLocale {
  en
  pt
}

// ---------------------------------------------------------------------------
// User & Auth
// ---------------------------------------------------------------------------

model User {
  id                     Int       @id @default(autoincrement()) @map("id")
  email                  String    @unique @map("email")
  name                   String?   @map("name")
  username               String?   @map("username")
  planId                 Int?      @map("plan_id")
  primaryLicenseId       String?   @map("primary_license_id")
  studyLevel             String?   @map("study_level")
  studyGoal              String?   @map("study_goal")
  onboardingCompletedAt  DateTime? @map("onboarding_completed_at")
  passwordHash           String    @map("password_hash")
  role                   UserRole  @default(user) @map("role")
  lastPasswordChangeAt   DateTime? @map("last_password_change_at")
  stripeCustomerId       String?   @unique @map("stripe_customer_id")
  subscriptionStatus     String?   @map("subscription_status")
  subscriptionExpiresAt  DateTime? @map("subscription_expires_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  licenseEntitlements  LicenseEntitlement[]
  passwordResetTokens  PasswordResetToken[]
  studyProgress        StudyProgress[]
  studySessions        StudySession[]
  userStreak           UserStreak?
  practiceStates       PracticeState[]
  testAttempts         TestAttempt[]
  questionScores       QuestionScore[]
  topicPerformances    TopicPerformance[]
  createdQuestions     Question[]          @relation("QuestionCreatedBy")
  reviewedQuestions    Question[]          @relation("QuestionReviewedBy")
  plan                 Plan?               @relation(fields: [planId], references: [id])
  subscriptionEvents   SubscriptionEvent[]
  studyEngines         StudyEngine[]
  weakTopicTrackers    WeakTopicTracker[]
  usageCounters        UsageCounter[]
  studyGoals           StudyGoal[]
  logbooks             Logbook[]

  @@index([planId])
  @@map("users")
}



model PasswordResetToken {
  id        Int       @id @default(autoincrement()) @map("id")
  userId    Int       @map("user_id")
  token     String    @unique @map("token")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}



// ---------------------------------------------------------------------------
// Entitlements
// ---------------------------------------------------------------------------

model LicenseEntitlement {
  id         Int       @id @default(autoincrement()) @map("id")
  userId     Int       @map("user_id")
  licenseId  String    @map("license_id") // "m" | "e" | "s" | "balloons" | "regs"
  enrolledAt DateTime  @default(now()) @map("enrolled_at")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, licenseId])
  @@index([userId, isActive])
  @@map("license_entitlements")
}

// ---------------------------------------------------------------------------
// Study Progress & Gamification
// ---------------------------------------------------------------------------

model StudyProgress {
  id         Int       @id @default(autoincrement()) @map("id")
  userId     Int       @map("user_id")
  licenseId  String    @map("license_id")
  moduleKey  String    @map("module_key")
  mode       StudyMode @map("mode")

  questionsTotal     Int @default(0) @map("questions_total")
  questionsCorrect   Int @default(0) @map("questions_correct")
  questionsIncorrect Int @default(0) @map("questions_incorrect")

  lastStudiedAt    DateTime? @map("last_studied_at")
  totalTimeSpentMs Int       @default(0) @map("total_time_spent_ms")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, moduleKey, mode])
  @@index([userId])
  @@index([userId, licenseId])
  @@map("study_progress")
}

model StudySession {
  id         Int       @id @default(autoincrement()) @map("id")
  userId     Int       @map("user_id")
  licenseId  String    @map("license_id")
  moduleKey  String    @map("module_key")
  mode       StudyMode @map("mode")

  createdAt  DateTime  @default(now()) @map("created_at")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")

  questionsAnswered Int   @default(0) @map("questions_answered")
  questionsCorrect  Int   @default(0) @map("questions_correct")
  score             Float?  @map("score")
  timeSpentMs       Int   @default(0) @map("time_spent_ms")

  details        String?   @map("details") // JSON stringified (individual answers)
  isQuickReview  Boolean   @default(false) @map("is_quick_review")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  user    User            @relation(fields: [userId], references: [id])
  answers SessionAnswer[]

  @@index([userId])
  @@index([userId, moduleKey])
  @@map("study_sessions")
}

model UserStreak {
  id             Int    @id @default(autoincrement()) @map("id")
  userId         Int    @unique @map("user_id")
  currentStreak  Int    @default(0) @map("current_streak")
  longestStreak  Int    @default(0) @map("longest_streak")
  lastActiveDate String @map("last_active_date") // "2026-03-24"
  totalXp        Int    @default(0) @map("total_xp")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_streaks")
}

// ---------------------------------------------------------------------------
// Practice & Test State Persistence
// ---------------------------------------------------------------------------

model PracticeState {
  id             Int      @id @default(autoincrement()) @map("id")
  userId         Int      @map("user_id")
  moduleKey      String   @map("module_key")

  currentIndex   Int      @default(0) @map("current_index")
  questionIds    String   @map("question_ids")    // JSON: ["q1","q2",...]
  answers        String   @default("{}") @map("answers") // JSON: {"q1":"A","q2":"C"}
  correctCount   Int      @default(0) @map("correct_count")
  incorrectCount Int      @default(0) @map("incorrect_count")

  createdAt DateTime  @default(now()) @map("created_at")
  startedAt DateTime  @default(now()) @map("started_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  expiresAt DateTime  @map("expires_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, moduleKey])
  @@index([userId])
  @@map("practice_states")
}

model TestAttempt {
  id         Int        @id @default(autoincrement()) @map("id")
  userId     Int        @map("user_id")
  moduleKey  String     @map("module_key")

  status     TestStatus @default(in_progress) @map("status")

  questionIds  String    @map("question_ids")    // JSON
  answers      String    @default("{}") @map("answers") // JSON
  currentIndex Int       @default(0) @map("current_index")

  createdAt  DateTime  @default(now()) @map("created_at")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  canceledAt DateTime? @map("canceled_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  score            Float? @map("score")
  questionsCorrect Int? @map("questions_correct")
  questionsTotal   Int? @map("questions_total")
  timeSpentMs      Int? @map("time_spent_ms")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, moduleKey, status])
  @@map("test_attempts")
}

// ---------------------------------------------------------------------------
// Logbook & Signature Flows
// ---------------------------------------------------------------------------

enum SignatoryStatus {
  draft
  pending
  verified
  needs_reverify
}

model Logbook {
  id        Int       @id @default(autoincrement()) @map("id")
  userId    Int?      @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user                   User?                  @relation(fields: [userId], references: [id])
  signatories            Signatory[]
  taskSignatureRequests  TaskSignatureRequest[]
  auditEvents            AuditEvent[]

  @@index([userId])
  @@map("logbooks")
}

model Signatory {
  id                 Int             @id @default(autoincrement()) @map("id")
  logbookId          Int             @map("logbook_id")
  slotNumber         Int?            @map("slot_number")
  name               String          @map("name")
  email              String          @map("email")
  licenceOrAuthNo    String?         @map("licence_or_auth_no")
  initials           String?         @map("initials")
  signatureSvg       String?         @map("signature_svg")
  signatureUpdatedAt DateTime?       @map("signature_updated_at")
  status             SignatoryStatus @default(draft) @map("status")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at")
  deletedAt          DateTime?       @map("deleted_at")

  logbook                      Logbook                       @relation(fields: [logbookId], references: [id])
  verificationRequests         SignatoryVerificationRequest[]
  taskSignatureRequests        TaskSignatureRequest[]

  @@unique([logbookId, slotNumber])
  @@index([logbookId])
  @@index([email])
  @@map("signatories")
}

model SignatoryVerificationRequest {
  id          Int       @id @default(autoincrement()) @map("id")
  signatoryId Int       @map("signatory_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  signatory Signatory @relation(fields: [signatoryId], references: [id])

  @@index([signatoryId])
  @@map("signatory_verification_requests")
}

model TaskSignatureRequest {
  id          Int       @id @default(autoincrement()) @map("id")
  logbookId   Int       @map("logbook_id")
  signatoryId Int       @map("signatory_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  payloadJson String    @map("payload_json")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  logbook   Logbook   @relation(fields: [logbookId], references: [id])
  signatory Signatory @relation(fields: [signatoryId], references: [id])

  @@index([logbookId])
  @@index([signatoryId])
  @@map("task_signature_requests")
}

model AuditEvent {
  id        Int       @id @default(autoincrement()) @map("id")
  logbookId Int?      @map("logbook_id")
  actorType String?   @map("actor_type")
  actorId   Int?      @map("actor_id")
  action    String    @map("action")
  metaJson  String?   @map("meta_json")
  ip        String?   @map("ip")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  logbook Logbook? @relation(fields: [logbookId], references: [id])

  @@index([logbookId])
  @@index([action])
  @@map("audit_events")
}

// ---------------------------------------------------------------------------
// Normalized Content & Admin Data
// ---------------------------------------------------------------------------

model License {
  id           String    @id @map("id")
  name         String    @map("name")
  description  String?   @map("description")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  modules Module[]

  @@map("licenses")
}

model Plan {
  id                     Int       @id @default(autoincrement()) @map("id")
  slug                   String    @unique @map("slug")
  name                   String    @map("name")
  description            String?   @map("description")
  price                  Decimal?  @db.Decimal(10, 2) @map("price")
  maxLicenses            Int       @default(0) @map("max_licenses")
  flashcardsLimit        Int       @default(0) @map("flashcards_limit")
  flashcardsUnit         LimitUnit @default(day) @map("flashcards_unit")
  practiceLimit          Int       @default(0) @map("practice_limit")
  practiceUnit           LimitUnit @default(day) @map("practice_unit")
  testsLimit             Int       @default(0) @map("tests_limit")
  testsUnit              LimitUnit @default(week) @map("tests_unit")
  maxQuestionsPerSession Int?      @map("max_questions_per_session")
  logbookAccess          Boolean   @default(false) @map("logbook_access")
  displayOrder           Int       @default(0) @map("display_order")
  stripeProductId        String?   @map("stripe_product_id")
  stripePriceMonthly     String?   @map("stripe_price_monthly")
  stripePriceAnnual      String?   @map("stripe_price_annual")
  trialDays              Int       @default(7) @map("trial_days")
  isActive               Boolean   @default(true) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  users User[]

  @@map("plans")
}

model Module {
  id           Int       @id @default(autoincrement()) @map("id")
  licenseId    String    @map("license_id")
  slug         String    @map("slug")
  moduleKey    String    @unique @map("module_key")
  name         String    @map("name")
  description  String?   @map("description")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  license  License   @relation(fields: [licenseId], references: [id])
  subjects Subject[]

  @@unique([licenseId, slug])
  @@index([licenseId])
  @@map("modules")
}

model Subject {
  id           Int       @id @default(autoincrement()) @map("id")
  moduleId     Int       @map("module_id")
  code         String    @map("code")
  name         String    @map("name")
  shortTitle   String?   @map("short_title")
  subtitle     String?   @map("subtitle")
  weight       Int       @default(1) @map("weight")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  module Module  @relation(fields: [moduleId], references: [id])
  topics Topic[]

  @@unique([moduleId, code])
  @@index([moduleId])
  @@map("subjects")
}

model Topic {
  id           Int       @id @default(autoincrement()) @map("id")
  subjectId    Int       @map("subject_id")
  code         String    @map("code")
  name         String    @map("name")
  displayOrder Int       @default(0) @map("display_order")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  subject   Subject     @relation(fields: [subjectId], references: [id])
  questions Question[]

  @@unique([subjectId, code])
  @@index([subjectId])
  @@map("topics")
}

model Question {
  id           Int            @id @default(autoincrement()) @map("id")
  externalId   String         @map("external_id")
  topicId      Int            @map("topic_id")
  locale       ContentLocale  @map("locale")
  questionType QuestionType   @default(single_choice) @map("question_type")
  stem         String         @map("stem")
  difficulty   Int?           @map("difficulty")
  status       QuestionStatus @default(draft) @map("status")
  version      Int            @default(1) @map("version")
  tags         String[]       @default([]) @map("tags")
  sourceFile   String?        @map("source_file")
  createdById  Int?           @map("created_by_id")
  reviewedById Int?           @map("reviewed_by_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  topic        Topic                       @relation(fields: [topicId], references: [id])
  createdBy    User?                       @relation("QuestionCreatedBy", fields: [createdById], references: [id])
  reviewedBy   User?                       @relation("QuestionReviewedBy", fields: [reviewedById], references: [id])
  options      QuestionOption[]
  explanation  QuestionExplanation?
  references   QuestionReference[]

  @@unique([externalId, locale])
  @@index([topicId])
  @@index([createdById])
  @@index([reviewedById])
  @@map("questions")
}

model QuestionOption {
  id           Int       @id @default(autoincrement()) @map("id")
  questionId   Int       @map("question_id")
  optionKey    String    @map("option_key")
  text         String    @map("text")
  isCorrect    Boolean   @default(false) @map("is_correct")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  question    Question                    @relation(fields: [questionId], references: [id])
  explanation QuestionOptionExplanation?

  @@unique([questionId, optionKey])
  @@index([questionId])
  @@map("question_options")
}

model QuestionExplanation {
  id                 Int       @id @default(autoincrement()) @map("id")
  questionId         Int       @unique @map("question_id")
  correctExplanation String?   @map("correct_explanation")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  question Question @relation(fields: [questionId], references: [id])

  @@map("question_explanations")
}

model QuestionOptionExplanation {
  id               Int       @id @default(autoincrement()) @map("id")
  questionOptionId Int       @unique @map("question_option_id")
  explanation      String    @map("explanation")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  questionOption QuestionOption @relation(fields: [questionOptionId], references: [id])

  @@map("question_option_explanations")
}

model QuestionReference {
  id           Int       @id @default(autoincrement()) @map("id")
  questionId   Int       @map("question_id")
  document     String?   @map("document")
  area         String?   @map("area")
  topicRef     String?   @map("topic_ref")
  locator      String?   @map("locator")
  note         String?   @map("note")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  question Question @relation(fields: [questionId], references: [id])

  @@index([questionId])
  @@map("question_references")
}

// Stripe
// ---------------------------------------------------------------------------

model Coupon {
  id              Int       @id @default(autoincrement()) @map("id")
  code            String    @unique @map("code")
  stripeId        String    @unique @map("stripe_id")
  percentOff      Int       @map("percent_off")
  annualOnly      Boolean   @default(true) @map("annual_only")
  maxRedemptions  Int?      @map("max_redemptions")
  timesRedeemed   Int       @default(0) @map("times_redeemed")
  expiresAt       DateTime? @map("expires_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@map("coupons")
}

model SubscriptionEvent {
  id            Int      @id @default(autoincrement()) @map("id")
  userId        Int      @map("user_id")
  stripeEventId String   @unique @map("stripe_event_id")
  eventType     String   @map("event_type")
  payload       Json     @map("payload")
  processedAt   DateTime @map("processed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("subscription_events")
}

// ---------------------------------------------------------------------------
// Question-level Scores & Session Answers & Topic Analytics
// ---------------------------------------------------------------------------

model QuestionScore {
  id                 Int      @id @default(autoincrement()) @map("id")
  userId             Int      @map("user_id")
  moduleKey          String   @map("module_key")
  questionExternalId String   @map("question_external_id")
  score              Int      @default(3) @map("score") // 0–5 mastery scale
  timesCorrect       Int      @default(0) @map("times_correct")
  timesIncorrect     Int      @default(0) @map("times_incorrect")
  lastAnsweredAt     DateTime @default(now()) @map("last_answered_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, questionExternalId])
  @@index([userId, moduleKey])
  @@map("question_scores")
}

model SessionAnswer {
  id                 Int      @id @default(autoincrement()) @map("id")
  sessionId          Int      @map("session_id")
  questionExternalId String   @map("question_external_id")
  selectedAnswer     String   @map("selected_answer") // 'A'|'B'|'C'|'D'
  isCorrect          Boolean  @map("is_correct")
  tcSectionCode      String?  @map("tc_section_code")
  tcTopicCode        String?  @map("tc_topic_code")
  answeredAt         DateTime @default(now()) @map("answered_at")

  session StudySession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, questionExternalId])
  @@index([sessionId])
  @@index([questionExternalId])
  @@map("session_answers")
}

model TopicPerformance {
  id               Int       @id @default(autoincrement()) @map("id")
  userId           Int       @map("user_id")
  moduleKey        String    @map("module_key")
  topicCode        String    @map("topic_code")
  topicTitle       String?   @map("topic_title")
  questionsTotal   Int       @default(0) @map("questions_total")
  questionsCorrect Int       @default(0) @map("questions_correct")
  lastStudiedAt    DateTime? @map("last_studied_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, moduleKey, topicCode])
  @@index([userId, moduleKey])
  @@map("topic_performance")
}

// ---------------------------------------------------------------------------
// Study Engine & Adaptive Learning
// ---------------------------------------------------------------------------

model StudyEngine {
  id                Int       @id @default(autoincrement()) @map("id")
  userId            Int       @map("user_id")
  licenseId         String    @map("license_id")
  moduleKey         String    @map("module_key")

  currentDifficulty Int       @default(3) @map("current_difficulty")  // 1-5
  difficultyTrend   String    @default("stable") @map("difficulty_trend") // "up"|"down"|"stable"
  recentScores      String    @default("[]") @map("recent_scores") // JSON: [85, 72, 90]
  windowSize        Int       @default(5) @map("window_size")
  upperThreshold    Int       @default(80) @map("upper_threshold")
  lowerThreshold    Int       @default(50) @map("lower_threshold")
  totalSessions     Int       @default(0) @map("total_sessions")
  avgScore          Float     @default(0) @map("avg_score")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, moduleKey])
  @@index([userId, licenseId])
  @@map("study_engines")
}

model WeakTopicTracker {
  id                  Int       @id @default(autoincrement()) @map("id")
  userId              Int       @map("user_id")
  moduleKey           String    @map("module_key")
  topicCode           String    @map("topic_code")
  errorCount          Int       @default(0) @map("error_count")
  totalAttempts       Int       @default(0) @map("total_attempts")
  errorRate           Float     @default(0) @map("error_rate")
  lastErrorAt         DateTime? @map("last_error_at")
  priority            Float     @default(0) @map("priority")
  nextReviewDate      DateTime? @map("next_review_date") // spaced repetition
  consecutiveCorrect  Int       @default(0) @map("consecutive_correct")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, moduleKey, topicCode])
  @@index([userId, moduleKey, priority(sort: Desc)])
  @@map("weak_topic_trackers")
}

model UsageCounter {
  id          Int       @id @default(autoincrement()) @map("id")
  userId      Int       @map("user_id")
  mode        StudyMode @map("mode")
  periodKey   String    @map("period_key") // "2026-04-06"|"2026-W14"|"2026-04"
  count       Int       @default(0) @map("count")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, mode, periodKey])
  @@index([userId, mode])
  @@map("usage_counters")
}

model StudyGoal {
  id          Int       @id @default(autoincrement()) @map("id")
  userId      Int       @map("user_id")
  title       String    @map("title")
  description String?   @map("description")
  targetType  String    @map("target_type") // "module_completion"|"avg_score"|"streak"|"custom"
  targetValue Float     @map("target_value")
  currentValue Float    @default(0) @map("current_value")
  targetDate  DateTime? @map("target_date")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isCompleted])
  @@map("study_goals")
}

